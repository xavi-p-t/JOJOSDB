<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.project.ControllerInfoLayout"
            prefWidth="529.0" prefHeight="400.0">

   <children>
      <!-- Contenedor vertical para apilar imagen, nombre, subtítulo y descripción -->
      <VBox spacing="10" alignment="TOP_CENTER"
            AnchorPane.topAnchor="10.0"
            AnchorPane.leftAnchor="10.0"
            AnchorPane.rightAnchor="10.0"
            AnchorPane.bottomAnchor="10.0">

         <!-- Imagen centrada -->
         <ImageView fx:id="imgInf"
                    fitHeight="200.0" fitWidth="300.0"
                    preserveRatio="true" />

         <!-- Nombre -->
         <Label fx:id="name"
                style="-fx-font-size: 18px; -fx-font-weight: bold;"
                maxWidth="Infinity"
                alignment="CENTER" />

         <!-- Subtítulo -->
         <Label fx:id="subt"
                style="-fx-font-size: 14px; -fx-text-fill: gray;"
                maxWidth="Infinity"
                alignment="CENTER" />

         <!-- Texto largo con saltos de línea automáticos -->
         <Text fx:id="desc"
               wrappingWidth="500.0"
               style="-fx-font-size: 14px;"
               VBox.vgrow="ALWAYS" />
      </VBox>
   </children>
</AnchorPane>
